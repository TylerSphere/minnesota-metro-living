---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const posts = allNews.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// Get unique cities for filter
const cities = [...new Set(posts.map(p => p.data.city).filter(Boolean))].sort();
---

<Layout
  title="Local News | Minnesota Metro Living"
  description="Stay current on what's happening across the Minnesota metro. Development projects, community updates, school news, and local stories from Edina, Maple Grove, Woodbury, and more."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10">
      <h1 class="text-4xl font-bold mb-4" style="color: #1e3a5f;">Local News</h1>
      <p class="text-lg text-gray-600 max-w-2xl">
        Community updates, development projects, and local stories from across the Minnesota metro area — updated regularly.
      </p>
    </div>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            href={`/news/${post.id}`}
            pubDate={post.data.pubDate}
            city={post.data.city}
            variant="news"
          />
        ))}
      </div>
    ) : (
      <div class="rounded-xl border-2 border-dashed border-gray-200 p-16 text-center text-gray-400">
        <p class="text-lg font-medium mb-2">Local news coming soon</p>
        <p class="text-sm">Our automated news agent publishes updates regularly.</p>
      </div>
    )}
  </div>
</Layout>

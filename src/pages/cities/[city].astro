---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const cities = await getCollection('cities');
  return cities.map(city => ({
    params: { city: city.id },
    props: { city },
  }));
}

const { city } = Astro.props;
const { Content } = await render(city);

// Related blog + news posts for this city
const allBlog = await getCollection('blog');
const allNews = await getCollection('news');

const relatedBlog = allBlog
  .filter(p => p.data.city?.toLowerCase() === city.data.name.toLowerCase())
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const relatedNews = allNews
  .filter(p => p.data.city?.toLowerCase() === city.data.name.toLowerCase())
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<Layout
  title={`Living in ${city.data.name}, MN | Minnesota Metro Living`}
  description={city.data.description}
  image={city.data.heroImage}
>
  <!-- City Hero -->
  <div class="relative h-64 sm:h-80 overflow-hidden" style={city.data.heroImage ? '' : 'background: linear-gradient(135deg, #1e3a5f 0%, #2d6a4f 100%);'}>
    {city.data.heroImage && (
      <img src={city.data.heroImage} alt={city.data.name} class="w-full h-full object-cover" />
    )}
    <div class="absolute inset-0 flex items-end" style="background: linear-gradient(to top, rgba(30,58,95,0.9) 0%, transparent 60%);">
      <div class="max-w-6xl mx-auto w-full px-4 sm:px-6 lg:px-8 pb-8">
        <p class="text-amber-400 text-sm font-semibold uppercase tracking-wide mb-1">Minnesota Metro</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-white">{city.data.name}</h1>
        <p class="text-blue-100 mt-2 text-lg">{city.data.tagline}</p>
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- Main content -->
      <div class="lg:col-span-2">
        <!-- Quick stats -->
        {(city.data.population || city.data.marketMedianPrice || city.data.commuteToMpls) && (
          <div class="grid grid-cols-3 gap-4 mb-8 p-5 rounded-xl border border-gray-200 bg-white">
            {city.data.population && (
              <div class="text-center">
                <p class="text-2xl font-bold" style="color: #1e3a5f;">{city.data.population}</p>
                <p class="text-xs text-gray-500 mt-0.5">Population</p>
              </div>
            )}
            {city.data.marketMedianPrice && (
              <div class="text-center border-x border-gray-100">
                <p class="text-2xl font-bold" style="color: #1e3a5f;">{city.data.marketMedianPrice}</p>
                <p class="text-xs text-gray-500 mt-0.5">Median Home Price</p>
              </div>
            )}
            {city.data.commuteToMpls && (
              <div class="text-center">
                <p class="text-2xl font-bold" style="color: #1e3a5f;">{city.data.commuteToMpls}</p>
                <p class="text-xs text-gray-500 mt-0.5">to Minneapolis</p>
              </div>
            )}
          </div>
        )}

        <!-- MDX Content -->
        <div class="prose max-w-none">
          <Content />
        </div>

        <!-- Related Blog Posts -->
        {relatedBlog.length > 0 && (
          <div class="mt-12">
            <h2 class="text-2xl font-bold mb-6" style="color: #1e3a5f;">Moving to {city.data.name}?</h2>
            <div class="flex flex-col gap-4">
              {relatedBlog.map(post => (
                <PostCard
                  title={post.data.title}
                  description={post.data.description}
                  href={`/blog/${post.id}`}
                  pubDate={post.data.pubDate}
                  city={post.data.city}
                  variant="blog"
                />
              ))}
            </div>
          </div>
        )}

        <!-- Related News -->
        {relatedNews.length > 0 && (
          <div class="mt-12">
            <h2 class="text-2xl font-bold mb-6" style="color: #1e3a5f;">Latest {city.data.name} News</h2>
            <div class="flex flex-col gap-4">
              {relatedNews.map(post => (
                <PostCard
                  title={post.data.title}
                  description={post.data.description}
                  href={`/news/${post.id}`}
                  pubDate={post.data.pubDate}
                  city={post.data.city}
                  variant="news"
                />
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <!-- Highlights -->
        {city.data.highlights.length > 0 && (
          <div class="rounded-xl border border-gray-200 bg-white p-5">
            <h3 class="font-bold text-lg mb-3" style="color: #1e3a5f;">Why {city.data.name}?</h3>
            <ul class="space-y-2">
              {city.data.highlights.map(h => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <span class="mt-1 flex-shrink-0 w-4 h-4 rounded-full flex items-center justify-center text-white text-xs" style="background-color: #2d6a4f;">✓</span>
                  {h}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Top Schools -->
        {city.data.topSchools && city.data.topSchools.length > 0 && (
          <div class="rounded-xl border border-gray-200 bg-white p-5">
            <h3 class="font-bold text-lg mb-3" style="color: #1e3a5f;">Top Schools</h3>
            <ul class="space-y-1.5">
              {city.data.topSchools.map(school => (
                <li class="text-sm text-gray-700">🎓 {school}</li>
              ))}
            </ul>
          </div>
        )}

        <!-- Pemberton CTA -->
        <div class="rounded-xl p-5 text-white" style="background: linear-gradient(135deg, #1e3a5f, #2d6a4f);">
          <p class="text-xs font-semibold uppercase tracking-wide text-amber-400 mb-1">Thinking of Moving?</p>
          <h3 class="font-bold text-lg mb-2">Talk to a {city.data.name} Expert</h3>
          <p class="text-sm text-blue-100 mb-4 leading-relaxed">
            Pemberton Real Estate has agents who live and work in {city.data.name}. Get real local insight before you decide.
          </p>
          <a
            href={city.data.pembertonContact?.url ?? 'https://www.pembertonre.com'}
            target="_blank"
            rel="noopener noreferrer"
            class="block text-center py-2 px-4 rounded-lg font-semibold text-white transition-opacity hover:opacity-90 text-sm"
            style="background-color: #d97706;"
          >
            {city.data.pembertonContact?.agentName ? `Contact ${city.data.pembertonContact.agentName}` : 'Find an Agent'}
          </a>
        </div>
      </aside>
    </div>
  </div>
</Layout>

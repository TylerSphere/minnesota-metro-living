---
interface Props {
  name: string;
  slug: string;
  tagline: string;
  heroImage?: string;
}

const { name, slug, tagline, heroImage } = Astro.props;
---

<a
  href={`/cities/${slug}`}
  class="group block rounded-xl overflow-hidden border border-gray-200 bg-white hover:shadow-lg transition-all duration-200 hover:-translate-y-0.5"
>
  <!-- Image area -->
  <div class="h-44 overflow-hidden relative" style="background-color: #1e3a5f;">
    {heroImage ? (
      <img
        src={heroImage}
        alt={`${name}, Minnesota`}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    ) : (
      <div class="w-full h-full flex items-end p-4" style="background: linear-gradient(135deg, #1e3a5f 0%, #2d6a4f 100%);">
        <svg class="absolute top-4 right-4 opacity-20 w-20 h-20" viewBox="0 0 24 24" fill="white">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
        </svg>
      </div>
    )}
    <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/60 to-transparent">
      <h3 class="text-white font-bold text-xl">{name}</h3>
      <p class="text-sm text-blue-100">Minnesota</p>
    </div>
  </div>

  <!-- Card body -->
  <div class="p-4">
    <p class="text-sm text-gray-600 leading-relaxed">{tagline}</p>
    <p class="mt-3 text-sm font-semibold group-hover:text-amber-600 transition-colors" style="color: #1e3a5f;">
      Explore {name} →
    </p>
  </div>
</a>

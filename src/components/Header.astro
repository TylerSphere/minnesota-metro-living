---
const navLinks = [
  { href: '/cities', label: 'Cities' },
  { href: '/blog', label: 'Moving Guides' },
  { href: '/news', label: 'Local News' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-50 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: #1e3a5f;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="white"/>
          </svg>
        </div>
        <span class="font-bold text-lg leading-tight" style="color: #1e3a5f;">
          Minnesota<br class="hidden sm:block" /><span class="text-sm font-medium sm:text-lg" style="color: #d97706;">Metro Living</span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors hover:text-amber-600 ${
              currentPath.startsWith(link.href)
                ? 'text-amber-600 border-b-2 border-amber-500 pb-0.5'
                : 'text-gray-600'
            }`}
          >
            {link.label}
          </a>
        ))}
        <a
          href="https://www.pembertonre.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-semibold px-4 py-2 rounded-lg text-white transition-colors"
          style="background-color: #1e3a5f;"
        >
          Find an Agent
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 rounded-md text-gray-600 hover:text-gray-900" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <nav id="mobile-menu" class="hidden md:hidden pb-4 border-t border-gray-100 pt-2">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block py-2 px-2 text-sm font-medium text-gray-700 hover:text-amber-600"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://www.pembertonre.com"
        target="_blank"
        rel="noopener noreferrer"
        class="block mt-2 text-center text-sm font-semibold px-4 py-2 rounded-lg text-white"
        style="background-color: #1e3a5f;"
      >
        Find an Agent
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
